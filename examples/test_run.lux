( === CLOISTER SYSTEM LIBRARY === )


( MMIO Base Addresses )
@port-system     12288 ; ( 0x3000 )
@port-screen     12320 ; ( 0x3020 )
@port-audio      12336 ; ( 0x3030 )
@port-controller 12352 ; ( 0x3040 )
@port-file       12384 ; ( 0x3060 )
@port-datetime   12400 ; ( 0x3070 )

@framebuffer     16384 ; ( 0x4000 )

( --- SCREEN --- )
@vector-screen!  port-screen STOREI ;
@pixel!
    64 * + 4 * framebuffer +
    STOREI
;

( --- AUDIO --- )
@vector-audio!   port-audio STOREI ;
@sound! ( id -- ) port-audio 4 + STOREI ;
    port-audio 4 + STOREI
;

( --- CONTROLLER --- )
@vector-controller! port-controller STOREI ;

( --- FILE --- )
@file-vector!  port-file STOREI ;
@file-name!    ( ptr -- ) port-file 4 + STOREI ;
@file-buffer!  ( ptr -- ) port-file 8 + STOREI ;
@file-read!
    16777216 ( Cmd 1 << 24 ) OR
    port-file 12 + STOREI
    port-file 12 + LOADI
;

( === System Library Test === )
MODULE SYSTEM
IMPORT SYSTEM AS SYS

( Word to print a number and a space )
@print . 32 emit ;

@on-vblank
    ( 1. Play sound )
    440 sound!
    
    ( 2. Write pixel )
    16777215 ( White ) 10 10 SYS::PIXEL!
;

@main
    "System lib test" 10 emit
    
    ( Set vectors )
    [ on-vblank ] SYS::VECTOR-SCREEN!
    
    "Unix Time: " SYS::UNIX-TS@ print 10 emit
    
    ( Infinite loop )
    [ 1 ] [ YIELD ] |: drop
;

main
