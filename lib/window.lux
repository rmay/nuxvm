( --- WINDOW --- )

MODULE WINDOW
@addr 0x100B0 ;
@scroll-y@  addr 4  + LOADI ;
@scroll-y!  addr 4  + STOREI ;
@scroll-x@  addr 8  + LOADI ;
@scroll-x!  addr 8  + STOREI ;
@visible-w@ addr 12 + LOADI ;
@visible-h@ addr 16 + LOADI ;
@total-w@   addr 20 + LOADI ;
@total-w!   addr 20 + STOREI ;
@total-h@   addr 24 + LOADI ;
@total-h!   addr 24 + STOREI ;
@bar-height addr 28 + LOADI ;
